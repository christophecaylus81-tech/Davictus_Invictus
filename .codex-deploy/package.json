{
  "name": "fusion-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Fusion MVP - assistant IA personnel souverain (Telegram + Inbox + GTD)",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
