NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://fusion:fusion@127.0.0.1:55432/fusion

# Telegram v1 cockpit
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_AUTO_PROCESS=true

# Future integrations
N8N_WEBHOOK_URL=
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIBE_MODEL=whisper-1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
ANTHROPIC_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.0-flash

# Daitivus Local Manager
DAITIVUS_MANAGER_PROVIDER=
DAITIVUS_OLLAMA_MANAGER_MODEL=llama3.2:latest
DAITIVUS_OLLAMA_EXECUTOR_MODEL=deepseek-r1:7b
DAITIVUS_CODEX_OUTPUT_DIR=workspace/local-manager/codex

# Dev agent worker
DEV_AGENT_WORKER_TOKEN=
DEV_AGENT_SERVER_URL=http://localhost:3001
DEV_AGENT_PROVIDER=codex
DEV_AGENT_WORKER_ID=davitus-local-worker
DEV_AGENT_REPO_PATH=
DEV_AGENT_POLL_INTERVAL_MS=5000
